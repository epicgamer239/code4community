rules_version = '2';

// Copy everything below into Firebase Console → Firestore Database → Rules → Edit rules → Publish

service cloud.firestore {
  match /databases/{database}/documents {

    // Users: each user can read and write only their own document (document id = auth.uid)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
